#: core/scripts/Global_persistentData.gd:162
msgid "AUDIO_MASTERVOLUME_DESC"
msgstr ""
"[b]Sesuaikan volume utama game.[/b]\n"
"\n"
"   Ayah dari semua volume! Volume lainnya tergantung olehnya..."

#: core/scripts/Global_persistentData.gd:163
msgid "AUDIO_MUSICVOLUME_DESC"
msgstr ""
"[b]Sesuaikan volume musik.[/b]\n"
"\n"
"   Ini untuk mengatur suara musik di game...! B-bukan kah ini cukup jelas?\n"
"\n"
"   Nih! Aku bantuin deh:\n"
"   [url]https://kbbi.web.id/suai[/url]"

#: core/scripts/Global_persistentData.gd:164
msgid "AUDIO_AMBIENCEVOLUME_DESC"
msgstr ""
"[b]Sesuaikan volume suasana.[/b]\n"
"\n"
"   Hmm... kamu pilih suasana kota atau musik? Apapun itu, disini kamu bisa "
"menyesuaikannya!"

#: core/scripts/Global_persistentData.gd:165
msgid "AUDIO_SFXVOLUME_DESC"
msgstr ""
"[b]Sesuaikan volume efek suara.[/b]\n"
"\n"
"   Tau efek suara kan? Yang itu loh... kalau kamu ngeklik sesuatu?"

#: core/scripts/Global_persistentData.gd:166
msgid "AUDIO_DIALOGUEVOLUME_DESC"
msgstr ""
"[b]Sesuaikan volume dialog.[/b]\n"
"\n"
"   Bunyi bip boop dan dialog suara diatur oleh penggeser ini...! Kalian suka "
"suara kami... kan?"

#: core/scripts/Global_persistentData.gd:167
msgid "VISUAL_WINDOWMODE_DESC"
msgstr ""
"[b]Atur mode jendela pada game.[/b]\n"
"\n"
"   Atur layar gamenya biar menuhin seluruh layar monitor mu, atau dibuat "
"mode jendela yang bisa kamu geser kemana saja~"

#: core/scripts/Global_persistentData.gd:168
msgid "VISUAL_MAXFPS_DESC"
msgstr ""
"[b]Batasi jumlah frame per detik yang dapat dijalankan oleh game.[/b]\n"
"\n"
"   Lebih cepat, leeebih lancaaar...! T-tapi jangan sampai prosesor kalian "
"terbakar yaa... pastiin layar kalian memiliki kecepatan refresh yang memadai!"

#: core/scripts/Global_persistentData.gd:169
msgid "VISUAL_VSYNC_DESC"
msgstr ""
"[b]Cegah screen tearing dengan menyinkronkan frame ke monitor kalian.[/b]\n"
"\n"
"   [i]Nonaktif[/i] - Tanpa sinkronisasi! Cepat, tetapi kemungkinan screen "
"tearing bakal terjadi!\n"
"\n"
"   [i]Aktif[/i] - Halus~\n"
"\n"
"   [i]Adaptif[/i] - Sinkronisasi jika diperlukan! Dan akan dinonaktifkan "
"sendiri jika FPS menurun!"

#: core/scripts/Global_persistentData.gd:170
msgid "VISUAL_TEXTUREQUALITY_DESC"
msgstr ""
"[b]Sesuaikan ketajaman dan detail tekstur.[/b]\n"
"\n"
"   Aku penasaran seperti apa sebenarnya tekstur ini... hmm..."

#: core/scripts/Global_persistentData.gd:171
msgid "VISUAL_SHADOWQUALITY_DESC"
msgstr ""
"[b]Atur seberapa detail bayangannya.[/b]\n"
"\n"
"   Oooh... bayangan halus~ Atau engga...?"

#: core/scripts/Global_persistentData.gd:172
msgid "VISUAL_BLOOM_DESC"
msgstr ""
"[b]Atur efek kecerahan dari cahaya.[/b]\n"
"\n"
"   MATAKUU!"

#: core/scripts/Global_persistentData.gd:173
msgid "VISUAL_MSAA_DESC"
msgstr ""
"[b]Haluskan tepi bergerigi pada objek.[/b]\n"
"\n"
"   Ucapkan selamat tinggal pada piksel yang kasar! Aku... harap?"

#: core/scripts/Global_persistentData.gd:174
msgid "VISUAL_MONOCHROMEFILTER_DESC"
msgstr ""
"[b]Atur visual permainan ke monokrom.[/b]\n"
" \n"
"   Ooohohoho! Kembali ke masa lalu, eh?"

#: core/scripts/Global_persistentData.gd:175
msgid "VISUAL_CAFILTER_DESC"
msgstr ""
"[b]Atur filter aberasi kromatik dalam game.[/b]\n"
"\n"
"[i]Nonaktif[/i] - Bersih~\n"
"\n"
"[i]Semua[/i] - Apakah seperti ini rasanya sakit kepala?\n"
"\n"
"[i]Ruang 3D[/i] - Hanya mempengaruhi dunia dalam game!"

#: core/scripts/Global_persistentData.gd:176
msgid "VISUAL_GRAINFILTER_DESC"
msgstr ""
"[b]Atur filter kasar pada layar di dalam game.[/b]\n"
" \n"
"   Waaahhhh! Berteksturr~"

#: core/scripts/Global_persistentData.gd:177
msgid "VISUAL_BLOODCENSOR_DESC"
msgstr ""
"[b]Sensor darah pada adegan di game.[/b]\n"
"\n"
"   Brr... kenapa dia pikir ini ide yang bagus...?"

#: core/scripts/Global_persistentData.gd:178
msgid "GAMEPLAY_LANGUAGEINTERFACE_DESC"
msgstr ""
"[b]Ubah bahasa antarmuka.[/b]\n"
"\n"
"   Ini kamu lagi baca antarmuka!"

#: core/scripts/Global_persistentData.gd:179
msgid "GAMEPLAY_LANGUAGEDIALOGUE_DESC"
msgstr ""
"[b]Ubah bahasa dialog.[/b]\n"
"\n"
"   Kamu ngerti kita ngomong apa kan..."

#: core/scripts/Global_persistentData.gd:180
msgid "GAMEPLAY_FPSMONITOR_DESC"
msgstr ""
"[b]Tampilkan frame per second (FPS) di layar.[/b]\n"
"\n"
"   Angka... begitu banyak angka... apa arti angka-angka ini, Raymond!?"

#: core/scripts/Global_persistentData.gd:181
msgid "GAMEPLAY_HOURFORMAT_DESC"
msgstr ""
"[b]Atur format jam di dalam game.[/b]\n"
"\n"
"   Kamu ngerti format 21:00 kan? Kan...?"

#: core/scripts/Global_persistentData.gd:182
msgid "GAMEPLAY_BUYTOGGLE_DESC"
msgstr ""
"[b]Atur tombol jual beli ke instan atau tertunda.[/b]\n"
"\n"
"   Aku mau beli ini dong...\n"
"\n"
"   Bisa cepet dikit engga?\n"
"\n"
"   Kenapa lama banget!?"

#: core/scripts/Global_persistentData.gd:183
msgid "DIALOG_DIACOLOR_DESC"
msgstr ""
"[b]Sesuaikan warna dialog.[/b]\n"
"\n"
"Ubah warna dialog sesuai keinginan mu!"

#: core/scripts/Global_persistentData.gd:184
msgid "DIALOG_NAMCOLOR_DESC"
msgstr ""
"[b]Sesuaikan warna nama.[/b]\n"
"\n"
"Ubah warna orang yang ngobrol ke kamu~"

#: core/scripts/Global_persistentData.gd:185
msgid "DIALOG_DIASIZE_DESC"
msgstr ""
"[b]Sesuaikan ukuran dialog.[/b]\n"
"\n"
"Aku ga bisa baca teksnya!"

#: core/scripts/Global_persistentData.gd:186
msgid "DIALOG_DIASPEED_DESC"
msgstr ""
"[b]Sesuaikan kecepatan dialog.[/b]\n"
"\n"
"Ngetiknya cepetan dikit napa?!"

