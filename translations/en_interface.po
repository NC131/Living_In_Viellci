#: core/scripts/Global_persistentData.gd:162
msgid "AUDIO_MASTERVOLUME_DESC"
msgstr ""
"[b]Adjust the main volume of the game.[/b]\n"
"\n"
"   The father of all volumes! All other volumes depend on him..."

#: core/scripts/Global_persistentData.gd:163
msgid "AUDIO_MUSICVOLUME_DESC"
msgstr ""
"[b]Adjust the music volume.[/b]\n"
"\n"
"   This adjust the music in the game...! I-isn't this self-explanatory "
"enough?\n"
"\n"
"   Here! Let me help you:\n"
"   [url]https://dictionary.cambridge.org/dictionary/english/adjust[/url]"

#: core/scripts/Global_persistentData.gd:164
msgid "AUDIO_AMBIENCEVOLUME_DESC"
msgstr ""
"[b]Adjust the ambience volume.[/b]\n"
"\n"
"   Hmm... you prefer the cityscape's ambience or the music? Whatever it is, "
"adjust the ambience here!"

#: core/scripts/Global_persistentData.gd:165
msgid "AUDIO_SFXVOLUME_DESC"
msgstr ""
"[b]Adjust the sound effects volume.[/b]\n"
"\n"
"   The sound effects! You know... the one when you click on things?"

#: core/scripts/Global_persistentData.gd:166
msgid "AUDIO_DIALOGUEVOLUME_DESC"
msgstr ""
"[b]Adjust the dialogue volume.[/b]\n"
"\n"
"   Bleeps and voice lines controlled by this slider! You don't hate our "
"voices... do you?"

#: core/scripts/Global_persistentData.gd:167
msgid "VISUAL_WINDOWMODE_DESC"
msgstr ""
"[b]Set the game's window mode.[/b]\n"
"\n"
"   Makes the game fully use your monitor or make it a window that you can "
"move around~"

#: core/scripts/Global_persistentData.gd:168
msgid "VISUAL_MAXFPS_DESC"
msgstr ""
"[b]Limit how many frames per second the game can run.[/b]\n"
"\n"
"   Faster, smoother...! J-just don't burn your processor... make sure your "
"display has the required refresh rate! "

#: core/scripts/Global_persistentData.gd:169
msgid "VISUAL_VSYNC_DESC"
msgstr ""
"[b]Prevent screen tearing by syncing frames to your monitor.[/b]\n"
"\n"
"   [i]Disabled[/i] - No sync! Fast, but expect screen tearing!\n"
"\n"
"   [i]Enabled[/i] - Smooth~\n"
"\n"
"   [i]Adaptive[/i] - Sync when needed! And it disables itself if the FPS is "
"dropping!"

#: core/scripts/Global_persistentData.gd:170
msgid "VISUAL_TEXTUREQUALITY_DESC"
msgstr ""
"[b]Adjust the sharpness and detail of textures.[/b]\n"
"\n"
"   I wonder what this texture actually looks like... hmm..."

#: core/scripts/Global_persistentData.gd:171
msgid "VISUAL_SHADOWQUALITY_DESC"
msgstr ""
"[b]Set how detailed the shadows appear.[/b]\n"
"\n"
"   Oooh... smooth shadows~ Or is it?"

#: core/scripts/Global_persistentData.gd:172
msgid "VISUAL_BLOOM_DESC"
msgstr ""
"[b]Toggle bloom effect from the light.[/b]\n"
"\n"
"   MY EYES!"

#: core/scripts/Global_persistentData.gd:173
msgid "VISUAL_MSAA_DESC"
msgstr ""
"[b]Smooth out jagged edges on objects.[/b]\n"
"\n"
"   Say goodbye to crunchy pixels! I... hope?"

#: core/scripts/Global_persistentData.gd:174
msgid "VISUAL_MONOCHROMEFILTER_DESC"
msgstr ""
"[b]Set the whole game to be monochrome.[/b]\n"
"\n"
"   Ooohohoho! Back to the good ol' days, eh?"

#: core/scripts/Global_persistentData.gd:175
msgid "VISUAL_CAFILTER_DESC"
msgstr ""
"[b]Toggle chromatic aberration filter in the game.[/b]\n"
"\n"
"   [i]Disabled[/i] - Clean~\n"
"\n"
"   [i]Global[/i] - Is this what it feels like to have a headache?\n"
"\n"
"   [i]3D Space[/i] - Affect the in-world only!"

#: core/scripts/Global_persistentData.gd:176
msgid "VISUAL_GRAINFILTER_DESC"
msgstr ""
"[b]Toggle grain filter in the game.[/b]\n"
"\n"
"   Whoaaa! Graiinyyy~"

#: core/scripts/Global_persistentData.gd:177
msgid "VISUAL_BLOODCENSOR_DESC"
msgstr ""
"[b]Censor blood in the scene.[/b]\n"
"\n"
"   Brr... why does he think this is a good idea...?"

#: core/scripts/Global_persistentData.gd:178
msgid "GAMEPLAY_LANGUAGEINTERFACE_DESC"
msgstr ""
"[b]Change the interface language.[/b]\n"
"\n"
"   You're currently reading the interface!"

#: core/scripts/Global_persistentData.gd:179
msgid "GAMEPLAY_LANGUAGEDIALOGUE_DESC"
msgstr ""
"[b]Change the dialogue language.[/b]\n"
"\n"
"   I hope you understand what we're talking..."

#: core/scripts/Global_persistentData.gd:180
msgid "GAMEPLAY_FPSMONITOR_DESC"
msgstr ""
"[b]Display your current frames per second on screen.[/b]\n"
"\n"
"   Numbers... the numbers... Raymond! What do they mean!?"

#: core/scripts/Global_persistentData.gd:181
msgid "GAMEPLAY_HOURFORMAT_DESC"
msgstr ""
"[b]Set the hour format.[/b]\n"
"\n"
"   I'm sure you can tell what 21:00 is, right? Right...?"

#: core/scripts/Global_persistentData.gd:182
msgid "GAMEPLAY_BUYTOGGLE_DESC"
msgstr ""
"[b]Toggle between instant or delayed buying and selling buttons.[/b]\n"
"\n"
"   I wanted to buy this, please...\n"
"\n"
"   Can you go a bit faster?\n"
"\n"
"   What's taking you so long!?"

#: core/scripts/Global_persistentData.gd:183
msgid "DIALOG_DIACOLOR_DESC"
msgstr ""
"[b]Adjust the dialogue color.[/b]\n"
"\n"
"   Change the color of the dialogue as you please!"

#: core/scripts/Global_persistentData.gd:184
msgid "DIALOG_NAMCOLOR_DESC"
msgstr ""
"[b]Adjust the name color.[/b]\n"
"\n"
"   Change the color of the person who talks to you~"

#: core/scripts/Global_persistentData.gd:185
msgid "DIALOG_DIASIZE_DESC"
msgstr ""
"[b]Adjust the dialogue size.[/b]\n"
"\n"
"   I can't read the text!"

#: core/scripts/Global_persistentData.gd:186
msgid "DIALOG_DIASPEED_DESC"
msgstr ""
"[b]Adjust the dialogue speed.[/b]\n"
"\n"
"   Type faster would ya?!"

